# ==========================================
# SECURITY: NEVER COMMIT ENVIRONMENT VARIABLES
# ==========================================
.env
.env.*

# ==========================================
# PYTHON VIRTUAL ENVIRONMENTS
# ==========================================
venv/
env/
.venv/
ENV/

# ==========================================
# PYTHON CACHE & COMPILED FILES
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# IDE & EDITOR WORKSPACES
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# LOGS & OS GENERATED FILES
# ==========================================
*.log
.DS_Store
Thumbs.db